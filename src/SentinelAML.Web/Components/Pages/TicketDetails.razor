@page "/ticket/{id:long}"

    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/chat/dashboard">Dashboard</a></li>
                    <li class="breadcrumb-item"><a href="/chat/tickets">Tickets</a></li>
                    <li class="breadcrumb-item active">TICKET-1841</li>
                </ol>
            </nav>
            <div class="d-flex align-items-center mb-2">
                <h2 class="fw-bold mb-0 me-3">Ticket: TICKET-1841</h2>
                <span class="badge bg-primary">Investigating</span>
                <span class="badge bg-danger ms-2">
                    <i class="bi bi-exclamation-circle-fill"></i> High Priority
                </span>
            </div>
            <p class="text-muted mb-0">
                Created: Jan 15, 2024 14:35:22 • 
                Assigned to: <strong>Michael Johnson</strong>
            </p>
        </div>
        <div class="col-md-4 text-md-end">
            <div class="dropdown d-inline-block me-2">
                <button class="btn btn-warning dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-arrow-repeat"></i> Change Status
                </button>
                <ul class="dropdown-menu">
                    <li><a class="dropdown-item" href="#"><i class="bi bi-folder2-open text-warning"></i> Open</a></li>
                    <li><a class="dropdown-item" href="#"><i class="bi bi-search text-primary"></i> Investigating</a></li>
                    <li><a class="dropdown-item" href="#"><i class="bi bi-exclamation-triangle text-danger"></i> Escalate</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#closeModal">
                        <i class="bi bi-check-circle text-success"></i> Close Ticket
                    </a></li>
                </ul>
            </div>
            <button class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#escalateModal">
                <i class="bi bi-arrow-up-circle"></i> Escalate
            </button>
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column: Main Content -->
        <div class="col-lg-8">
            <!-- Ticket Summary Card -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-info-circle text-primary"></i>
                        Ticket Summary
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Ticket ID</p>
                            <p class="fw-bold mb-0"><code class="fs-6">Ticket-1841</code></p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Related Alert</p>
                            <p class="mb-0">
                                <a href="/chat/alerts/details/ALT-9284" class="text-decoration-none">
                                    <code>ALT-9284</code>
                                    <i class="bi bi-box-arrow-up-right small ms-1"></i>
                                </a>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Customer</p>
                            <p class="mb-0 fw-semibold">John Peterson</p>
                            <small class="text-muted">CUST-4521</small>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Transaction Amount</p>
                            <p class="mb-0 fw-bold text-danger">$15,420.00 USD</p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">Risk Score</p>
                            <p class="mb-0">
                                <span class="badge bg-danger fs-6">85</span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p class="text-muted small mb-1">SLA Status</p>
                            <div class="progress mt-1" style="height: 20px;">
                                <div class="progress-bar bg-warning" role="progressbar" style="width: 65%">
                                    1d 6h remaining
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Investigation Notes & Comments -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-chat-left-text text-info"></i>
                        Investigation Notes & Comments
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Comment Thread -->
                    <div class="mb-4">
                        <!-- Comment 1 -->
                        <div class="d-flex mb-3">
                            <div class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center me-3" 
                                 style="width: 40px; height: 40px; flex-shrink: 0;">
                                MJ
                            </div>
                            <div class="flex-grow-1">
                                <div class="bg-light rounded p-3">
                                    <div class="d-flex justify-content-between mb-2">
                                        <strong>Michael Johnson</strong>
                                        <small class="text-muted">15 mins ago</small>
                                    </div>
                                    <p class="mb-0">Initial investigation started. Reviewing customer transaction history and patterns. Large incoming transaction from Iran raises significant concerns. Checking if customer has legitimate business ties to the region.</p>
                                </div>
                            </div>
                        </div>

                        <!-- Comment 2 -->
                        <div class="d-flex mb-3">
                            <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center me-3" 
                                 style="width: 40px; height: 40px; flex-shrink: 0;">
                                DL
                            </div>
                            <div class="flex-grow-1">
                                <div class="bg-light rounded p-3">
                                    <div class="d-flex justify-content-between mb-2">
                                        <strong>David Lee</strong>
                                        <small class="text-muted">1 hour ago</small>
                                    </div>
                                    <p class="mb-0">Ticket assigned to Michael. Please prioritize this - customer has no prior history with high-risk countries. Need enhanced due diligence.</p>
                                </div>
                            </div>
                        </div>

                        <!-- System Event -->
                        <div class="d-flex mb-3">
                            <div class="bg-secondary text-white rounded-circle d-inline-flex align-items-center justify-content-center me-3" 
                                 style="width: 40px; height: 40px; flex-shrink: 0;">
                                <i class="bi bi-robot"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="bg-light rounded p-3 border-start border-4 border-info">
                                    <div class="d-flex justify-content-between mb-2">
                                        <strong>System</strong>
                                        <small class="text-muted">2 hours ago</small>
                                    </div>
                                    <p class="mb-0"><i class="bi bi-info-circle"></i> Ticket created from Alert ALT-9284. Status: Open → Investigating.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Add Comment Form -->
                    <div class="border-top pt-3">
                        <h6 class="fw-semibold mb-3">Add Investigation Note</h6>
                        <form>
                            <div class="mb-3">
                                <textarea class="form-control" rows="3" 
                                          placeholder="Document your findings, actions taken, or next steps..."></textarea>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="markInternal">
                                    <label class="form-check-label small" for="markInternal">
                                        Internal note (not visible in audit reports)
                                    </label>
                                </div>
                                <div>
                                    <button type="button" class="btn btn-outline-secondary me-2">
                                        <i class="bi bi-paperclip"></i> Attach File
                                    </button>
                                    <button type="button" class="btn btn-primary">
                                        <i class="bi bi-send"></i> Add Comment
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Evidence & Documents -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0">
                            <i class="bi bi-file-earmark-text text-warning"></i>
                            Evidence & Documents
                        </h5>
                        <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#uploadModal">
                            <i class="bi bi-upload"></i> Upload
                        </button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-file-pdf text-danger fs-4 me-3"></i>
                                <div>
                                    <div class="fw-semibold">customer_kyc_documents.pdf</div>
                                    <small class="text-muted">Uploaded by M. Johnson • 30 mins ago • 2.4 MB</small>
                                </div>
                            </div>
                            <div>
                                <button class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-download"></i>
                                </button>
                            </div>
                        </div>
                        <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-file-excel text-success fs-4 me-3"></i>
                                <div>
                                    <div class="fw-semibold">transaction_analysis.xlsx</div>
                                    <small class="text-muted">Uploaded by M. Johnson • 1 hour ago • 1.1 MB</small>
                                </div>
                            </div>
                            <div>
                                <button class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-download"></i>
                                </button>
                            </div>
                        </div>
                        <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-image text-primary fs-4 me-3"></i>
                                <div>
                                    <div class="fw-semibold">wire_transfer_screenshot.png</div>
                                    <small class="text-muted">System generated • 2 hours ago • 856 KB</small>
                                </div>
                            </div>
                            <div>
                                <button class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-download"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Decision Panel -->
            <div class="card border-0 shadow-sm border-start border-success border-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="fw-bold mb-0">
                        <i class="bi bi-clipboard-check text-success"></i>
                        Final Decision
                    </h5>
                </div>
                <div class="card-body">
                    <p class="text-muted mb-3">After completing the investigation, select the appropriate action:</p>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <button class="btn btn-outline-success w-100" data-bs-toggle="modal" data-bs-target="#approveModal">
                                <i class="bi bi-check-circle fs-4 d-block mb-2"></i>
                                <strong>Approve</strong>
                                <small class="d-block text-muted">No suspicious activity</small>
                            </button>
                        </div>
                        <div class="col-md-4">
                            <button class="btn btn-outline-danger w-100" data-bs-toggle="modal" data-bs-target="#rejectModal">
                                <i class="bi bi-x-circle fs-4 d-block mb-2"></i>
                                <strong>Reject</strong>
                                <small class="d-block text-muted">Block transaction</small>
                            </button>
                        </div>
                        <div class="col-md-4">
                            <button class="btn btn-outline-warning w-100" data-bs-toggle="modal" data-bs-target="#sarModal">
                                <i class="bi bi-flag fs-4 d-block mb-2"></i>
                                <strong>File SAR</strong>
                                <small class="d-block text-muted">Report to authorities</small>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Sidebar -->
        <div class="col-lg-4">
            <!-- Quick Actions -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0">Quick Actions</h6>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <button class="btn btn-outline-primary">
                            <i class="bi bi-person-plus"></i> Reassign Ticket
                        </button>
                        <button class="btn btn-outline-info">
                            <i class="bi bi-clock-history"></i> Request Extension
                        </button>
                        <button class="btn btn-outline-secondary">
                            <i class="bi bi-file-earmark-pdf"></i> Generate Report
                        </button>
                        <button class="btn btn-outline-warning">
                            <i class="bi bi-telephone"></i> Contact Customer
                        </button>
                    </div>
                </div>
            </div>

            <!-- Customer Profile (Compact) -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-person-circle"></i>
                        Customer Info
                    </h6>
                </div>
                <div class="card-body">
                    <div class="text-center mb-3">
                        <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center" 
                             style="width: 60px; height: 60px;">
                            <i class="bi bi-person-fill text-primary" style="font-size: 30px;"></i>
                        </div>
                        <h6 class="fw-bold mt-2 mb-0">John Peterson</h6>
                        <small class="text-muted">CUST-4521</small>
                    </div>
                    <hr>
                    <div class="small">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Risk Level:</span>
                            <span class="badge bg-danger">HIGH</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Country:</span>
                            <strong>USA</strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Account Age:</span>
                            <strong>1.6 years</strong>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Total Transactions:</span>
                            <strong>847</strong>
                        </div>
                    </div>
                    <hr>
                    <a href="#" class="btn btn-sm btn-outline-primary w-100">
                        View Full Profile
                    </a>
                </div>
            </div>

            <!-- Timeline / Activity Log -->
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <h6 class="fw-bold mb-0">
                        <i class="bi bi-clock-history text-info"></i>
                        Activity Timeline
                    </h6>
                </div>
                <div class="card-body">
                    <div class="timeline-vertical">
                        <div class="timeline-item mb-3">
                            <div class="d-flex">
                                <div class="timeline-marker bg-primary me-3"></div>
                                <div class="flex-grow-1">
                                    <p class="small mb-0 fw-semibold">Status changed to Investigating</p>
                                    <small class="text-muted">M. Johnson • 15 mins ago</small>
                                </div>
                            </div>
                        </div>
                        <div class="timeline-item mb-3">
                            <div class="d-flex">
                                <div class="timeline-marker bg-success me-3"></div>
                                <div class="flex-grow-1">
                                    <p class="small mb-0 fw-semibold">Ticket assigned to M. Johnson</p>
                                    <small class="text-muted">D. Lee • 1 hour ago</small>
                                </div>
                            </div>
                        </div>
                        <div class="timeline-item mb-3">
                            <div class="d-flex">
                                <div class="timeline-marker bg-warning me-3"></div>
                                <div class="flex-grow-1">
                                    <p class="small mb-0 fw-semibold">Ticket created from alert</p>
                                    <small class="text-muted">System • 2 hours ago</small>
                                </div>
                            </div>
                        </div>
                        <div class="timeline-item mb-3">
                            <div class="d-flex">
                                <div class="timeline-marker bg-danger me-3"></div>
                                <div class="flex-grow-1">
                                    <p class="small mb-0 fw-semibold">Alert ALT-9284 triggered</p>
                                    <small class="text-muted">System • 2 hours ago</small>
                                </div>
                            </div>
                        </div>
                        <div class="timeline-item">
                            <div class="d-flex">
                                <div class="timeline-marker bg-info me-3"></div>
                                <div class="flex-grow-1">
                                    <p class="small mb-0 fw-semibold">Transaction received</p>
                                    <small class="text-muted">System • 2 hours ago</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Close Ticket Modal -->
<div class="modal fade" id="closeModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Close Ticket</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Closure Reason</label>
                        <select class="form-select">
                            <option>Approved - No suspicious activity</option>
                            <option>Rejected - Transaction blocked</option>
                            <option>False Positive</option>
                            <option>Escalated to authorities</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Summary</label>
                        <textarea class="form-control" rows="4" 
                                  placeholder="Provide a summary of the investigation and decision rationale..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success">Close Ticket</button>
            </div>
        </div>
    </div>
</div>

<!-- Escalate Modal -->
<div class="modal fade" id="escalateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Escalate Ticket</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle"></i>
                    Escalating this ticket will notify senior management and trigger enhanced review procedures.
                </div>
                <form>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Escalation Reason</label>
                        <select class="form-select">
                            <option>Potential money laundering</option>
                            <option>Terrorist financing concerns</option>
                            <option>Sanctions violation</option>
                            <option>Complex investigation required</option>
                            <option>Other (specify below)</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Details</label>
                        <textarea class="form-control" rows="4" 
                                  placeholder="Provide detailed justification for escalation..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger">Escalate Ticket</button>
            </div>
        </div>
    </div>
</div>

<!-- Upload Document Modal -->
<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Upload Evidence</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Document Type</label>
                        <select class="form-select">
                            <option>KYC Documents</option>
                            <option>Transaction Records</option>
                            <option>Communication Logs</option>
                            <option>Investigation Notes</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">File</label>
                        <input class="form-control" type="file">
                        <div class="form-text">Supported formats: PDF, XLSX, DOCX, PNG, JPG (Max: 10MB)</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Description</label>
                        <textarea class="form-control" rows="2" 
                                  placeholder="Brief description of this document..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary">Upload</button>
            </div>
        </div>
    </div>
</div>

<!-- Custom CSS for vertical timeline -->
<style>
    .timeline-vertical {
        position: relative;
        padding-left: 30px;
    }
    .timeline-vertical::before {
        content: '';
        position: absolute;
        left: 8px;
        top: 0;
        bottom: 0;
        width: 2px;
        background: #dee2e6;
    }
    .timeline-marker {
        position: absolute;
        left: -26px;
        width: 16px;
        height: 16px;
        border-radius: 50%;
        border: 3px solid #fff;
    }
</style>

@code {
    [Parameter]
    public long Id { get; set; }
}
