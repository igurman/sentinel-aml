@page "/alert/{id:long}"
@using SentinelAML.Application.Services
@using SentinelAML.Domain.Entities
@using SentinelAML.Web.Components.Elements
@rendermode InteractiveServer
@inject AlertService AlertService;

@if(alert != null) {
<div class="row mb-4">
    <div class="col-md-8">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
                <li class="breadcrumb-item"><a href="/alert">Alerts</a></li>
                <li class="breadcrumb-item active">ALT-@Id</li>
            </ol>
        </nav>
        <h2 class="fw-bold mb-1">Alert Details: ALT-@Id</h2>
        <p class="text-muted mb-0">@alert.CreatedAt | Created on Jan 15, 2024 at 14:32:15 •
            <span class="badge bg-warning">Open</span>
        </p>
    </div>
    <div class="col-md-4 text-md-end">
        <div class="btn-group mb-2 mb-md-0">
            <DropdownMenu ClassName="alert-detail-dropdown" Icon="bi-folder-plus" Title="Create Ticket" MainAction="OnActiveBtn">
                <Items>
                    <li><a class="dropdown-item" @onclick="CloseAlert"><i class="bi bi-x-circle"></i> Close Alert</a></li>
                    <li><a class="dropdown-item" @onclick="MarkFalse"><i class="bi bi-check-circle"></i> Mark False Positive</a></li>
                </Items>
            </DropdownMenu>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column: Main Details -->
    <div class="col-lg-8">
        <!-- Risk Score Summary Card -->
        <div class="card border-0 shadow-sm mb-4 border-start border-danger border-4">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-3 text-center border-end">
                        <h6 class="text-muted small mb-2">RISK SCORE</h6>
                        <div class="display-4 fw-bold text-danger">@alert.RiskScore</div>
                        <span class="badge bg-danger mt-2">HIGH RISK</span>
                    </div>
                    <div class="col-md-9">
                        <h6 class="fw-semibold mb-3">Risk Breakdown</h6>
                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                    <span class="small">
                                        <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                                        Large Transaction Rule
                                    </span>
                                <span class="badge bg-danger">+50</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-danger" style="width: 59%"></div>
                            </div>
                        </div>
                        <div class="mb-2">
                            <div class="d-flex justify-content-between mb-1">
                                    <span class="small">
                                        <i class="bi bi-geo-alt-fill text-warning"></i>
                                        High Risk Country Rule
                                    </span>
                                <span class="badge bg-warning">+30</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-warning" style="width: 35%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="d-flex justify-content-between mb-1">
                                    <span class="small">
                                        <i class="bi bi-lightning-fill text-info"></i>
                                        High Frequency Rule
                                    </span>
                                <span class="badge bg-info">+5</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-info" style="width: 6%"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Transaction Details Card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 pt-3">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-arrow-left-right text-primary"></i>
                    Transaction Details
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border-start border-primary border-3 ps-3">
                            <p class="text-muted small mb-1">Transaction ID</p>
                            <p class="fw-semibold mb-0"><code>TXN-@alert.TransactionId</code></p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border-start border-primary border-3 ps-3">
                            <p class="text-muted small mb-1">Amount</p>
                            <p class="fw-bold mb-0 fs-5 text-danger">$@alert.Transaction?.Amount USD | $15,420.00 USD</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border-start border-primary border-3 ps-3">
                            <p class="text-muted small mb-1">Direction</p>
                            <p class="mb-0">
                                    <span class="badge bg-primary bg-opacity-10 text-primary">
                                        <i class="bi bi-arrow-down"></i> @alert.Transaction?.Direction
                                    </span>
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border-start border-primary border-3 ps-3">
                            <p class="text-muted small mb-1">Counterparty Country</p>
                            <p class="mb-0">
                                    <span class="badge bg-danger">
                                        <i class="bi bi-flag"></i> Iran (IR) | @alert.Transaction?.CounterpartyCountry
                                    </span>
                            </p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border-start border-primary border-3 ps-3">
                            <p class="text-muted small mb-1">Timestamp</p>
                            <p class="mb-0">Jan 15, 2024 14:32:15 UTC | @alert.Transaction?.Timestamp</p>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border-start border-primary border-3 ps-3">
                            <p class="text-muted small mb-1">Processing Status</p>
                            <p class="mb-0">
                                <span class="badge bg-success">@alert.Status</span>
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Customer Transaction History -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h5 class="fw-bold mb-0">
                    <i class="bi bi-clock-history text-info"></i>
                    Recent Transaction History (Last 30 Days)
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                        <tr>
                            <th class="border-0">Date</th>
                            <th class="border-0">Transaction ID</th>
                            <th class="border-0">Amount</th>
                            <th class="border-0">Direction</th>
                            <th class="border-0">Country</th>
                            <th class="border-0">Risk</th>
                        </tr>
                        </thead>
                        <tbody>
                        <tr class="table-warning">
                            <td>Jan 15, 14:32</td>
                            <td><code class="small">TXN-8392</code></td>
                            <td class="fw-bold">$15,420.00</td>
                            <td><i class="bi bi-arrow-down text-success"></i> In</td>
                            <td><span class="badge bg-danger">IR</span></td>
                            <td><span class="badge bg-danger">85</span></td>
                        </tr>
                        <tr>
                            <td>Jan 14, 09:15</td>
                            <td><code class="small">TXN-8301</code></td>
                            <td>$2,340.00</td>
                            <td><i class="bi bi-arrow-up text-danger"></i> Out</td>
                            <td><span class="badge bg-secondary">USA</span></td>
                            <td><span class="badge bg-success">12</span></td>
                        </tr>
                        <tr>
                            <td>Jan 13, 16:42</td>
                            <td><code class="small">TXN-8289</code></td>
                            <td>$1,120.00</td>
                            <td><i class="bi bi-arrow-down text-success"></i> In</td>
                            <td><span class="badge bg-secondary">UK</span></td>
                            <td><span class="badge bg-success">8</span></td>
                        </tr>
                        <tr>
                            <td>Jan 12, 11:20</td>
                            <td><code class="small">TXN-8276</code></td>
                            <td>$5,600.00</td>
                            <td><i class="bi bi-arrow-up text-danger"></i> Out</td>
                            <td><span class="badge bg-secondary">FR</span></td>
                            <td><span class="badge bg-warning">45</span></td>
                        </tr>
                        <tr>
                            <td>Jan 10, 13:55</td>
                            <td><code class="small">TXN-8251</code></td>
                            <td>$890.00</td>
                            <td><i class="bi bi-arrow-down text-success"></i> In</td>
                            <td><span class="badge bg-secondary">DE</span></td>
                            <td><span class="badge bg-success">5</span></td>
                        </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white border-0 text-center">
                <a href="#" class="btn btn-sm btn-outline-primary">View Full History</a>
            </div>
        </div>
    </div>

    <!-- Right Column: Customer Profile & Actions -->
    <div class="col-lg-4">
        <!-- Customer Profile Card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-person-circle"></i>
                    Customer Profile
                </h5>
            </div>
            <div class="card-body">
                <div class="text-center mb-3">
                    <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center"
                         style="width: 80px; height: 80px;">
                        <i class="bi bi-person-fill text-primary" style="font-size: 40px;"></i>
                    </div>
                    <h5 class="fw-bold mt-2 mb-0">@alert.Customer?.Name</h5>
                    <p class="text-muted small mb-0">Customer ID: CUST-@alert.Customer?.Id</p>
                </div>

                <hr>

                <div class="mb-3">
                    <p class="text-muted small mb-1">Risk Level</p>
                    <span class="badge bg-danger">HIGH RISK</span>
                </div>

                <div class="mb-3">
                    <p class="text-muted small mb-1">Country</p>
                    <p class="mb-0 fw-semibold">United States | @alert.Customer?.Country</p>
                </div>

                <div class="mb-3">
                    <p class="text-muted small mb-1">Account Created</p>
                    <p class="mb-0">Jun 12, 2022</p>
                </div>

                <div class="mb-3">
                    <p class="text-muted small mb-1">PEP Status</p>
                    <p class="mb-0">
                        <span class="badge bg-secondary">@GetPepVal(alert)</span>
                    </p>
                </div>

                <div class="mb-3">
                    <p class="text-muted small mb-1">30-Day Transaction Volume</p>
                    <p class="mb-0 fw-bold text-primary">$24,370.00</p>
                </div>

                <div class="mb-3">
                    <p class="text-muted small mb-1">Total Transactions</p>
                    <p class="mb-0">847 transactions</p>
                </div>

                <hr>

                <div class="d-grid">
                    <a href="#" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-person-lines-fill"></i> Full KYC Profile
                    </a>
                </div>
            </div>
        </div>

        <!-- Related Alerts Card -->
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-link-45deg text-warning"></i>
                    Related Alerts
                </h6>
            </div>
            <div class="card-body">
                <div class="list-group list-group-flush">
                    <a href="#" class="list-group-item list-group-item-action border-0 px-0">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <code class="small">ALT-9102</code>
                                <p class="mb-1 small">High Frequency</p>
                                <small class="text-muted">Jan 8, 2024</small>
                            </div>
                            <span class="badge bg-success">Closed</span>
                        </div>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action border-0 px-0">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <code class="small">ALT-8894</code>
                                <p class="mb-1 small">Large Transaction</p>
                                <small class="text-muted">Dec 28, 2023</small>
                            </div>
                            <span class="badge bg-secondary">False Positive</span>
                        </div>
                    </a>
                </div>
                <div class="text-center mt-2">
                    <a href="#" class="btn btn-sm btn-link">View All (5)</a>
                </div>
            </div>
        </div>

        <!-- Activity Log -->
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="fw-bold mb-0">
                    <i class="bi bi-activity text-success"></i>
                    Activity Log
                </h6>
            </div>
            <div class="card-body">
                <div class="timeline">
                    <div class="timeline-item mb-3">
                        <div class="timeline-marker bg-warning"></div>
                        <div class="timeline-content">
                            <p class="small mb-0 fw-semibold">Alert Created</p>
                            <small class="text-muted">System • 2 mins ago</small>
                        </div>
                    </div>
                    <div class="timeline-item mb-3">
                        <div class="timeline-marker bg-info"></div>
                        <div class="timeline-content">
                            <p class="small mb-0">Transaction processed</p>
                            <small class="text-muted">System • 2 mins ago</small>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-marker bg-success"></div>
                        <div class="timeline-content">
                            <p class="small mb-0">Transaction received</p>
                            <small class="text-muted">System • 3 mins ago</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
}

@code {
    [Parameter] public long Id { get; set; }
    private Alert? alert;
    
    protected override async Task OnInitializedAsync() {
        await LoadData();
    }

    private async Task LoadData() {
        alert = await AlertService.GetById(Id);
        
    }
    
    static string GetPepVal(Alert alert) {
        return alert.Customer?.IsPep == true ? "PEP" : "Not PEP"; 
    }
    
    private static void OnActiveBtn() {
        Console.WriteLine("OnActiveBtn");
    }
    
    static void CloseAlert() {
        Console.WriteLine("CloseAlert");
    }

    static void MarkFalse() {
        Console.WriteLine("MarkFalse");
    }
    
}


