@page "/"

<PageTitle>Home</PageTitle>

    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold mb-1">AML Dashboard</h2>
            <p class="text-muted">Real-time monitoring and risk analytics</p>
        </div>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Transactions Today</p>
                            <h3 class="fw-bold mb-0" id="total-transactions">1,247</h3>
                            <small class="text-success">
                                <i class="bi bi-arrow-up"></i> 12.5% from yesterday
                            </small>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded">
                            <i class="bi bi-arrow-left-right text-primary fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Alerts Today</p>
                            <h3 class="fw-bold mb-0 text-warning" id="total-alerts">43</h3>
                            <small class="text-danger">
                                <i class="bi bi-arrow-up"></i> 8 new in last hour
                            </small>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded">
                            <i class="bi bi-exclamation-triangle text-warning fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Open Tickets</p>
                            <h3 class="fw-bold mb-0 text-danger" id="open-tickets">12</h3>
                            <small class="text-muted">
                                3 escalated
                            </small>
                        </div>
                        <div class="bg-danger bg-opacity-10 p-3 rounded">
                            <i class="bi bi-folder-open text-danger fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Avg Risk Score</p>
                            <h3 class="fw-bold mb-0" id="avg-risk">34.2</h3>
                            <small class="text-success">
                                <i class="bi bi-arrow-down"></i> 5.3% from yesterday
                            </small>
                        </div>
                        <div class="bg-info bg-opacity-10 p-3 rounded">
                            <i class="bi bi-speedometer2 text-info fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-3 mb-4">
        <!-- Alerts Timeline Chart -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold">Alerts Timeline (24h)</h5>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-outline-secondary active">24H</button>
                            <button type="button" class="btn btn-outline-secondary">7D</button>
                            <button type="button" class="btn btn-outline-secondary">30D</button>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <canvas id="alertsTimelineChart" height="80"></canvas>
                </div>
            </div>
        </div>

        <!-- Risk Distribution Chart -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 pt-3">
                    <h5 class="mb-0 fw-bold">Risk Distribution</h5>
                </div>
                <div class="card-body">
                    <canvas id="riskDistributionChart"></canvas>
                    <div class="mt-3">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="small"><span class="badge bg-success">●</span> Low Risk</span>
                            <span class="small fw-bold">62%</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="small"><span class="badge bg-warning">●</span> Medium Risk</span>
                            <span class="small fw-bold">28%</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="small"><span class="badge bg-danger">●</span> High Risk</span>
                            <span class="small fw-bold">10%</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent High-Risk Transactions -->
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-0 pt-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold">Recent High-Risk Transactions</h5>
                        <a href="/chat/alerts" class="btn btn-sm btn-outline-primary">View All Alerts</a>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                            <tr>
                                <th class="border-0">Transaction ID</th>
                                <th class="border-0">Customer</th>
                                <th class="border-0">Amount</th>
                                <th class="border-0">Country</th>
                                <th class="border-0">Risk Score</th>
                                <th class="border-0">Timestamp</th>
                                <th class="border-0">Action</th>
                            </tr>
                            </thead>
                            <tbody id="high-risk-transactions">
                            <tr>
                                <td><code class="small">TXN-8392...</code></td>
                                <td>
                                    <div class="fw-semibold">John Peterson</div>
                                    <small class="text-muted">CUST-4521</small>
                                </td>
                                <td class="fw-bold">$15,420.00</td>
                                <td>
                                    <span class="badge bg-danger bg-opacity-10 text-danger">IR</span>
                                </td>
                                <td>
                                    <span class="badge bg-danger">85</span>
                                </td>
                                <td class="text-muted small">2 mins ago</td>
                                <td>
                                    <a href="/chat/alerts/details/xxx" class="btn btn-sm btn-outline-primary">Review</a>
                                </td>
                            </tr>
                            <tr>
                                <td><code class="small">TXN-8391...</code></td>
                                <td>
                                    <div class="fw-semibold">Maria Garcia</div>
                                    <small class="text-muted">CUST-8932</small>
                                </td>
                                <td class="fw-bold">$8,750.00</td>
                                <td>
                                    <span class="badge bg-warning bg-opacity-10 text-warning">RU</span>
                                </td>
                                <td>
                                    <span class="badge bg-warning">72</span>
                                </td>
                                <td class="text-muted small">5 mins ago</td>
                                <td>
                                    <a href="/chat/alerts/details/xxx" class="btn btn-sm btn-outline-primary">Review</a>
                                </td>
                            </tr>
                            <tr>
                                <td><code class="small">TXN-8388...</code></td>
                                <td>
                                    <div class="fw-semibold">Ahmed Hassan</div>
                                    <small class="text-muted">CUST-2341</small>
                                </td>
                                <td class="fw-bold">$12,200.00</td>
                                <td>
                                    <span class="badge bg-danger bg-opacity-10 text-danger">SY</span>
                                </td>
                                <td>
                                    <span class="badge bg-danger">90</span>
                                </td>
                                <td class="text-muted small">12 mins ago</td>
                                <td>
                                    <a href="/chat/alerts/details/xxx" class="btn btn-sm btn-outline-primary">Review</a>
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Charts Initialization -->
    <script>
    const alertsCtx = document.getElementById('alertsTimelineChart').getContext('2d');
    const alertsChart = new Chart(alertsCtx, {
        type: 'line',
        data: {
            labels: ['00:00', '02:00', '04:00', '06:00', '08:00', '10:00', '12:00', '14:00', '16:00', '18:00', '20:00', '22:00'],
            datasets: [{
                label: 'Alerts',
                data: [2, 1, 0, 3, 8, 12, 15, 18, 14, 10, 7, 5],
                borderColor: '#ffc107',
                backgroundColor: 'rgba(255, 193, 7, 0.1)',
                tension: 0.4,
                fill: true
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            plugins: {
                legend: { display: false }
            },
            scales: {
                y: { beginAtZero: true }
            }
        }
    });
    
    const riskCtx = document.getElementById('riskDistributionChart').getContext('2d');
    const riskChart = new Chart(riskCtx, {
        type: 'doughnut',
        data: {
            labels: ['Low Risk', 'Medium Risk', 'High Risk'],
            datasets: [{
                data: [62, 28, 10],
                backgroundColor: ['#198754', '#ffc107', '#dc3545'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: false,
            maintainAspectRatio: true,
            plugins: {
                legend: { display: false }
            }
        }
    });
</script>


