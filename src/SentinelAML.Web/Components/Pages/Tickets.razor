@page "/ticket"
@using SentinelAML.Application.DTOs
@using SentinelAML.Application.Risk
@using SentinelAML.Application.Services
@using SentinelAML.Domain.Constants
@using SentinelAML.Web.Components.Elements
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@inject TicketService TicketService;

<!-- Page Header -->
<div class="row mb-4">
    <div class="col-md-6">
        <h2 class="fw-bold mb-1">Ticket Management</h2>
        <p class="text-muted">Investigation and compliance workflow</p>
    </div>
    <div class="col-md-6 text-md-end">
        <button class="btn btn-outline-secondary me-2">
            <i class="bi bi-download"></i> Export Report
        </button>
        <button class="btn btn-primary">
            <i class="bi bi-funnel"></i> Advanced Filters
        </button>
    </div>
</div>

<!-- Summary Statistics -->
<CardBigWrap Cards="@Cards" CssColNumber="3"/>

<div class="row">
    <div class="col-12">

        <!-- Filter -->
        <div class="card mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-lg-3">
                        <label class="form-label small fw-semibold">Search Tickets</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control border-start-0" placeholder="Ticket ID"
                                   id="searchInput" @bind="filter.Name">
                        </div>
                    </div>

                    <div class="col-lg-3">
                        <label class="form-label small fw-semibold">Status</label>
                        <select class="form-select" id="statusFilter" @bind="filter.Status">
                            <option value="">All Statuses</option>
                            <option value="open">Open</option>
                            <option value="investigating">Investigating</option>
                            <option value="escalated">Escalated</option>
                            <option value="closed">Closed</option>
                        </select>
                    </div>

                    <div class="col-lg-2">
                        <label class="form-label small fw-semibold">Priority</label>
                        <select class="form-select" id="priorityFilter" @bind="filter.Priority">
                            <option value="">All Priorities</option>
                            <option value="high">High</option>
                            <option value="medium">Medium</option>
                            <option value="low">Low</option>
                        </select>
                    </div>

                    <div class="col-lg-2">
                        <label class="form-label small fw-semibold">Assigned Officer</label>
                        <select class="form-select" id="assignedFilter" @bind="filter.Assigned">
                            <option value="">All Officers</option>
                            <option value="Graysen Jacobs">Graysen Jacobs</option>
                            <option value="Sarah Williams">Sarah Williams</option>
                            <option value="David Lee">David Lee</option>
                            <option value="unassigned">Unassigned</option>
                        </select>
                    </div>

                    <div class="col-lg-2 d-flex align-items-end">
                        <button class="btn btn-primary w-100 me-2" id="applyFilters" @onclick="FilterAction"><i
                                class="bi bi-funnel"></i>Apply
                        </button>
                        <button class="btn btn-outline-secondary" id="clearFilters" @onclick="FilterClean"><i
                                class="bi bi-x"></i></button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Table -->
        <div class="card">
            <div class="card-header bg-white border-0 pt-3">
                <ul class="nav nav-tabs card-header-tabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#allTickets" type="button">
                            All Tickets <span class="badge bg-secondary ms-1">@(pageInit?.TotalItems ?? 0)</span>
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#myTickets" type="button">
                            My Tickets <span class="badge bg-primary ms-1">8</span>
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#urgent" type="button">
                            Urgent <span class="badge bg-danger ms-1">4</span>
                        </button>
                    </li>
                </ul>
            </div>
            <div class="card-body p-0">
                <div class="tab-content">
                    <div id="allTickets" class="tab-pane fade show active">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                <tr>
                                    <th>Ticket ID <i class="bi bi-arrow-down-up small ms-1"></i></th>
                                    <th>Customer <i class="bi bi-arrow-down-up small ms-1"></i></th>
                                    <th>Alert ID <i class="bi bi-arrow-down-up small ms-1"></i></th>
                                    <th>Priority <i class="bi bi-arrow-down-up small ms-1"></i></th>
                                    <th>Status <i class="bi bi-arrow-down-up small ms-1"></i></th>
                                    <th>Assigned To <i class="bi bi-arrow-down-up small ms-1"></i></th>
                                    <th>Created <i class="bi bi-arrow-down-up small ms-1"></i></th>
                                    <th>SLA <i class="bi bi-arrow-down-up small ms-1"></i></th>
                                    <th>Action <i class="bi bi-arrow-down-up small ms-1"></i></th>
                                </tr>
                                </thead>
                                <tbody>
                                @if (ticketsList != null) {
                                    @foreach (var ticket in ticketsList) {
                                        <tr class="@(ticket.Status.ToString().Equals("Closed") ? "table-secondary opacity-50" : "")">
                                            <td><code>TICKET-@ticket.Id</code></td>
                                            <td>
                                                <div class="fw-semibold">@ticket.Alert?.Customer?.Name</div>
                                                <div class="text-muted">CST-@ticket.Alert?.Customer?.Id</div>
                                            </td>
                                            <td>
                                                <a href="/alert/@ticket.Alert?.Id" class="text-decoration-none">
                                                    <code class="small">ALT-@ticket.Alert?.Id</code>
                                                </a>
                                            </td>
                                            <td>@GetPriority(@ticket.Priority)</td>
                                            <td>
                                                <span class="badge bg-@GetStatus(ticket.Status)">@ticket.Status</span>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div
                                                        class="bg-success text-white rounded-circle d-inline-flex align-items-center justify-content-center me-2"
                                                        style="width: 28px; height: 28px; font-size: 12px;">
                                                        MJ
                                                    </div>
                                                    <small>@ticket.AssignedTo</small>
                                                </div>
                                                @* <span class="badge bg-secondary">Unassigned</span> *@
                                            </td>
                                            <td class="small text-muted">
                                                <div>@ticket.CreatedAt.Date.ToString("MMMM dd, yyyy")</div>
                                                <div>@ticket.CreatedAt.TimeOfDay.ToString(@"hh\:mm\:ss")</div>
                                            </td>
                                            <td>
                                                @if (ticket.Status.ToString().Equals("Closed")) {
                                                    <span class="badge bg-success">
                                                        <i class="bi bi-check-circle"></i> On Time
                                                    </span>
                                                }
                                                else {
                                                    <div class="progress" style="height: 6px; width: 60px;">
                                                        <div class="progress-bar bg-success" style="width: 50%"></div>
                                                    </div>
                                                    <small class="text-success">1d 18h left</small>
                                                }
                                            </td>
                                            <td>
                                                <a href="/ticket/@ticket.Id" type="button"
                                                   class="btn btn-sm btn-outline-@(ticket.Status.ToString().Equals("Closed") ? "secondary" : "primary") w-75">
                                                    @(ticket.Status.ToString().Equals("Closed") ? "View" : "Review")
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div id="myTickets" class="tab-pane fade">
                        <div class="p-5 text-center text-muted">
                            <i class="bi bi-inbox display-1"></i>
                            <p class="mt-3">Your assigned tickets will appear here</p>
                        </div>
                    </div>
                    <div id="urgent" class="tab-pane fade">
                        <div class="p-5 text-center text-muted">
                            <i class="bi bi-exclamation-triangle display-1"></i>
                            <p class="mt-3">Urgent tickets requiring immediate attention</p>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Pagination -->
            <div class="card-footer bg-white border-0">
                <div class="row align-items-center">
                    <Pagination
                        LoadData="LoadData"
                        PageInit="pageInit"
                        CurrentPage="currentPage"
                        PageSize="pageSize"/>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<TicketDto>? ticketsList;
    private PageInit? pageInit;
    private int currentPage = 1;
    private int pageSize = 5;
    private readonly TicketViewFilter filter = new();
    private List<CardDto> Cards = [];

    protected override async Task OnInitializedAsync() {
        InitCards();
        await LoadData();
    }

    private async Task LoadData(PaginationRequest? request = null) {
        if (request != null) {
            currentPage = request.CurrentPage;
            pageSize = request.PageSize;
        }

        (ticketsList, pageInit, var statusMap) = await TicketService.GetTicketsFilterPaginated(
            filter,
            currentPage,
            pageSize
        );

        foreach (var card in Cards) {
            if (card.Status != null) {
                card.Value = statusMap.TryGetValue(card.Status, out var value) ? value.ToString() : "0";
            }
        }
    }

    private async Task FilterAction() {
        currentPage = 1;
        await LoadData();
    }

    private async Task FilterClean() {
        currentPage = 1;
        filter.Clean();
        await LoadData();
    }

    /**
     * formatting
     */
    private void InitCards() {
        Cards = [
            CardDto.builder()
                .Title("OPEN")
                .Color("warning")
                .Description("Awaiting assignment")
                .Icon("bi-folder2-open")
                .Status(nameof(TicketStatus.Open))
                .Build(),
            CardDto.builder()
                .Title("INVESTIGATING")
                .Color("primary")
                .Description("Active investigations")
                .Icon("bi-search")
                .Status(nameof(TicketStatus.Investigating))
                .Build(),
            CardDto.builder()
                .Title("ESCALATED")
                .Color("danger")
                .Description("Require attention")
                .Icon("bi-exclamation-triangle")
                .Status(nameof(TicketStatus.Escalated))
                .Build(),
            CardDto.builder()
                .Title("AVG RESOLUTION TIME")
                .Value("2.4d")
                .Color("success")
                .Description("<i class=\"bi bi-arrow-down\"></i> 12% faster")
                .Icon("bi-clock-history")
                .Build()
        ];
    }

    private static RuleDictionary? GetRule(string ruleName)
        => RuleDictionary.FromName(ruleName);

    private static string GetRiskScore(int riskScore) {
        return riskScore switch {
            >= 80 and < 90 => "warning",
            >= 90 => "danger",
            _ => "success"
        };
    }

    private static string GetStatus(TicketStatus status) {
        return status.ToString() switch {
            "Open" => "warning",
            "Investigating" => "primary",
            "Escalated" => "danger",
            "Closed" => "success",
            _ => ""
        };
    }
    
    private static RenderFragment GetPriority(TicketPriorityType value) {
        return value.ToString() switch {
            "Low" => @<span class="badge bg-secondary">
                         <i class="bi bi-circle-fill"></i> Low
                     </span>,
            "Medium" => @<span class="badge bg-warning">
                            <i class="bi bi-dash-circle-fill"></i> Medium
                        </span>,
            "High" => @<span class="badge bg-danger">
                          <i class="bi bi-exclamation-circle-fill"></i> High
                      </span>,
            _ => @<span></span>
        };
    }

    private static string AmountFormat(TicketDto ticketDto) {
        // if (ticketDto.Transaction?.Amount == null) return "";
        //
        // var result =  ticketDto.Transaction.Amount.ToString("N2", CultureInfo.InvariantCulture)
        //     .Replace(',', ' ')
        //     .Replace(',', '.');
        // return $"${result}";
        return "none";
    }

}
