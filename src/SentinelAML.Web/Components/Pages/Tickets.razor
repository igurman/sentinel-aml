@page "/ticket"

<!-- Page Header -->
<div class="row mb-4">
    <div class="col-md-6">
        <h2 class="fw-bold mb-1">Ticket Management</h2>
        <p class="text-muted">Investigation and compliance workflow</p>
    </div>
    <div class="col-md-6 text-md-end">
        <button class="btn btn-outline-secondary me-2">
            <i class="bi bi-download"></i> Export Report
        </button>
        <button class="btn btn-primary">
            <i class="bi bi-funnel"></i> Advanced Filters
        </button>
    </div>
</div>

<!-- Summary Statistics -->
<div class="row g-3 mb-4">
    <div class="col-lg-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">OPEN TICKETS</p>
                        <h3 class="fw-bold mb-1 text-warning">8</h3>
                        <small class="text-muted">Awaiting assignment</small>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-3 rounded">
                        <i class="bi bi-folder2-open text-warning fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">INVESTIGATING</p>
                        <h3 class="fw-bold mb-1 text-primary">15</h3>
                        <small class="text-muted">Active investigations</small>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded">
                        <i class="bi bi-search text-primary fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">ESCALATED</p>
                        <h3 class="fw-bold mb-1 text-danger">4</h3>
                        <small class="text-danger">Require attention</small>
                    </div>
                    <div class="bg-danger bg-opacity-10 p-3 rounded">
                        <i class="bi bi-exclamation-triangle text-danger fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-3 col-md-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small">AVG RESOLUTION TIME</p>
                        <h3 class="fw-bold mb-1 text-success">2.4d</h3>
                        <small class="text-success">
                            <i class="bi bi-arrow-down"></i> 12% faster
                        </small>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded">
                        <i class="bi bi-clock-history text-success fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filters Panel -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-lg-3">
                <label class="form-label small fw-semibold">Search Tickets</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text" class="form-control border-start-0" 
                           placeholder="Ticket ID or Customer" id="ticketSearch">
                </div>
            </div>

            <div class="col-lg-2">
                <label class="form-label small fw-semibold">Status</label>
                <select class="form-select" id="statusFilter">
                    <option value="">All Statuses</option>
                    <option value="open">Open</option>
                    <option value="investigating">Investigating</option>
                    <option value="escalated">Escalated</option>
                    <option value="closed">Closed</option>
                </select>
            </div>

            <div class="col-lg-2">
                <label class="form-label small fw-semibold">Priority</label>
                <select class="form-select" id="priorityFilter">
                    <option value="">All Priorities</option>
                    <option value="high">High</option>
                    <option value="medium">Medium</option>
                    <option value="low">Low</option>
                </select>
            </div>

            <div class="col-lg-3">
                <label class="form-label small fw-semibold">Assigned Officer</label>
                <select class="form-select" id="officerFilter">
                    <option value="">All Officers</option>
                    <option value="1">Michael Johnson</option>
                    <option value="2">Sarah Williams</option>
                    <option value="3">David Lee</option>
                    <option value="unassigned">Unassigned</option>
                </select>
            </div>

            <div class="col-lg-2 d-flex align-items-end">
                <button class="btn btn-primary w-100">
                    <i class="bi bi-funnel"></i> Apply
                </button>
            </div>
        </div>
    </div>
</div>

