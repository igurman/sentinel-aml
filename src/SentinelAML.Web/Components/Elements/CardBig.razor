@using SentinelAML.Application.DTOs
<div class="card border-0 shadow-sm h-100">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
            <div>
                <p class="text-muted mb-1 small">@Card.Title</p>
                <h3 class="fw-bold mb-1 text-@Card.Color">@Card.Value</h3>
                <small class="text-muted">@GetDescription(Card)</small>
            </div>
            <div class="bg-@Card.Color bg-opacity-10 p-3 rounded">
                <i class="bi @Card.Icon text-@Card.Color fs-4"></i>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public required CardDto Card { get; set; }

    private static MarkupString GetDescription(CardDto card) {
        return new MarkupString(card.Description ?? string.Empty);
    }
}