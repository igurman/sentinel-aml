@using SentinelAML.Application.DTOs
<div class="card border-0 border-start border-@Card.Color border-4 shadow-sm">
    <div class="card-body">
        <h6 class="text-muted small mb-1">@Card.Title</h6>
        <h4 class="fw-bold mb-0">@Card.Value</h4>
    </div>
</div>

@code {
    [Parameter]
    public required CardDto Card { get; set; }
}